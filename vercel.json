{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://lucid-sound-domain-api-lucidsounddomain.vercel.app/api/$1"
    },
    {
      "src": "/admin",
      "dest": "https://lucid-sound-domain-api-lucidsounddomain.vercel.app/api/admin-portal"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
