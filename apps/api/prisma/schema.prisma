generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id
  email     String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  visitors  Visitor[]
  events    Event[]
}

model Session {
  id         String   @id
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Visitor {
  id        String   @id
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User? @relation(fields: [userId], references: [id])
  events Event[]
}

// Waitlist — email OR phone (or both) identify a person.
// name stays nullable so we can unify records later on the profile page.
model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  visitorId   String
  userId      String?
  type        String
  properties  String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([visitorId])
  @@index([userId])
}

