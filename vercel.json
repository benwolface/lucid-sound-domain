{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lucid-sound-domain-api-lucidsounddomain.vercel.app/api/:path*"
    },
    {
      "source": "/admin",
      "destination": "https://lucid-sound-domain-api-lucidsounddomain.vercel.app/admin"
    }
  ]
}
