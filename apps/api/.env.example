NODE_ENV=development
API_PORT=8787

# SQLite database file (created automatically by Prisma migrations)
DATABASE_URL="file:./dev.db"

# Used for CORS in local dev (optional if frontend uses Vite proxy)
WEB_ORIGIN="http://localhost:5173"

# How long the session lasts (in days). Auth cookie uses this by default.
SESSION_DAYS=30

