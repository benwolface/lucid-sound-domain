NODE_ENV=development
API_PORT=8787

# Used for CORS in local dev (optional if frontend uses Vite proxy)
WEB_ORIGIN="http://localhost:5173"

# How long the session lasts (in days). Auth cookie uses this by default.
SESSION_DAYS=30

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Twilio — owner notification + blast SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=        # e.g. +15551234567 (your Twilio number)
TWILIO_TO=          # your personal number for owner join-notifications

# Admin API — protect /api/admin/* routes with this secret
# Pass as header: x-admin-secret: <value>
ADMIN_SECRET=
